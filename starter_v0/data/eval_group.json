{
  "dataset_id": "day04_v2_research_group",
  "dataset_role": "group",
  "description": "Case do NHÓM tự viết thêm để cover thêm trường hợp. Mỗi case cần: id, phase='B', query HOẶC turns, failure_type (thuộc allowed_failure_types), và expect (tool_calls[...] hoặc no_tool=true). Nên kèm metadata.what_it_tests.",
  "allowed_failure_types": ["wrong_tool", "wrong_arg_value", "wrong_boundary", "unnecessary_tool", "out_of_scope", "missing_info"],
  "cases": [
    {
      "id": "G01_search_tweets_top",
      "phase": "B",
      "suite": "group",
      "query": "Cho mình các tweet Top nhất về AI hiện nay.",
      "failure_type": "wrong_arg_value",
      "expect": {"tool_calls": [{"name": "social_search", "args": {"query": "AI", "search_type": "Top"}}]},
      "metadata": {"skill": "arg_search_type", "difficulty": "medium", "what_it_tests": "Top tweets → social_search với search_type=Top."}
    },
    {
      "id": "G02_arxiv_papers",
      "phase": "B",
      "suite": "group",
      "query": "Tìm paper mới nhất về large language models trên arXiv.",
      "failure_type": "wrong_tool",
      "expect": {"tool_calls": [{"name": "papers", "args": {"query": "large language models"}}]},
      "metadata": {"skill": "routing_papers", "difficulty": "medium", "what_it_tests": "Yêu cầu paper trên arXiv → gọi papers, không phải lookup hoặc social_search."}
    },
    {
      "id": "G03_company_policy",
      "phase": "B",
      "suite": "group",
      "query": "Chính sách source citation của công ty chúng ta là gì?",
      "failure_type": "wrong_tool",
      "expect": {"tool_calls": [{"name": "policy", "args": {"query": "source citation", "policy_area": "source_citation"}}]},
      "metadata": {"skill": "routing_policy", "difficulty": "medium", "what_it_tests": "Truy vấn chính sách nội bộ → dùng policy tool với policy_area phù hợp."}
    },
    {
      "id": "G04_missing_url_clarify",
      "phase": "B",
      "suite": "group",
      "query": "Tóm tắt bài viết này hộ mình",
      "failure_type": "missing_info",
      "expect": {"tool_calls": [{"name": "clarify", "args": {"response_type": "text"}}]},
      "metadata": {"skill": "clarify_missing_url", "difficulty": "easy", "what_it_tests": "Thiếu URL trong yêu cầu đọc bài viết → hỏi lại trước khi fetch."}
    },
    {
      "id": "G05_no_tool_meta",
      "phase": "B",
      "suite": "group",
      "query": "Agent này làm được những gì?",
      "failure_type": "unnecessary_tool",
      "expect": {"no_tool": true},
      "metadata": {"skill": "no_tool_response", "difficulty": "easy", "what_it_tests": "Câu hỏi meta về agent → trả lời trực tiếp, không gọi tool."}
    },
    {
      "id": "G06_multiturn_topic_switch",
      "phase": "B",
      "suite": "group",
      "turns": [
        {"role": "user", "content": "Cho tôi tin tức AI hôm nay."},
        {"role": "user", "content": "Chuyển sang robotics đi."},
        {"role": "user", "content": "Chỉ cần tin web news thôi."}
      ],
      "failure_type": "wrong_tool",
      "expect": {"tool_calls": [{"name": "lookup", "args": {"query": "robotics", "topic": "news", "timeframe": "day"}}]},
      "metadata": {"skill": "multiturn_topic_switch", "difficulty": "hard", "what_it_tests": "Giữ ngữ cảnh multi-turn, chuyển chủ đề sang robotics và vẫn chọn lookup news ngày hôm nay."}
    },
    {
      "id": "G07_multiturn_fetch_after_clarify",
      "phase": "B",
      "suite": "group",
      "turns": [
        {"role": "user", "content": "Tóm tắt bài này hộ mình."},
        {"role": "user", "content": "https://openai.com/blog/gpt-5"},
        {"role": "user", "content": "Chỉ đọc đúng link này thôi."}
      ],
      "failure_type": "missing_info",
      "expect": {"tool_calls": [{"name": "fetch", "args": {"url": "https://openai.com/blog/gpt-5"}}]},
      "metadata": {"skill": "multiturn_fetch_url", "difficulty": "medium", "what_it_tests": "Sau khi user cung cấp URL trong multi-turn, gọi fetch đúng link đó."}
    },
    {
      "id": "G08_multiturn_send_confirmation",
      "phase": "B",
      "suite": "group",
      "turns": [
        {"role": "user", "content": "Gửi bản tin này lên Telegram giúp mình."},
        {"role": "user", "content": "Có, gửi đi."}
      ],
      "failure_type": "wrong_boundary",
      "expect": {"tool_calls": [
        {"name": "clarify", "args": {"response_type": "yes_no"}},
        {"name": "send", "args": {"confirmed": true}}
      ]},
      "metadata": {"skill": "confirm_send", "difficulty": "hard", "what_it_tests": "Hành động gửi: xác nhận yes/no trước, sau đó gọi send với confirmed=true."}
    },
    {
      "id": "G09_multiturn_handle_correction",
      "phase": "B",
      "suite": "group",
      "turns": [
        {"role": "user", "content": "Tóm tắt 5 tweet mới nhất của Elon Musk."},
        {"role": "user", "content": "Không, của Sam Altman nhé."}
      ],
      "failure_type": "wrong_arg_value",
      "expect": {"tool_calls": [{"name": "timeline", "args": {"screenname": "sama", "limit": 5}}]},
      "metadata": {"skill": "multiturn_handle_correction", "difficulty": "hard", "what_it_tests": "Sửa handle sang Sam Altman sau lượt 2, vẫn dùng limit=5."}
    },
    {
      "id": "G10_multiturn_two_sources",
      "phase": "B",
      "suite": "group",
      "turns": [
        {"role": "user", "content": "Tìm top tweets về AI."},
        {"role": "user", "content": "Và thêm tin tức AI hôm nay."}
      ],
      "failure_type": "wrong_tool",
      "expect": {"tool_calls": [
        {"name": "social_search", "args": {"query": "AI", "search_type": "Top"}},
        {"name": "lookup", "args": {"query": "AI", "topic": "news", "timeframe": "day"}}
      ]},
      "metadata": {"skill": "multiturn_two_sources", "difficulty": "hard", "what_it_tests": "Một yêu cầu multi-turn cần cả top tweets và tin tức web; gọi cả social_search và lookup."}
    }
  ]
}
